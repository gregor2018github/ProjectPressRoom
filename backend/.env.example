# Copy this file to .env and adjust values as needed.
# All variables are optional — defaults are shown here.

# Path to the SQLite database file.
PRESSROOM_DB_PATH=./data/pressroom.sqlite

# Identifies the fetcher to feed hosts.
PRESSROOM_USER_AGENT=pressroom/0.1 (+https://github.com/gregor2018github/ProjectPressroom)

# Per-request HTTP timeout in seconds.
PRESSROOM_FETCH_TIMEOUT=15

# Maximum number of feeds fetched concurrently.
PRESSROOM_FETCH_CONCURRENCY=4

# Standard Python logging level: DEBUG | INFO | WARNING | ERROR
PRESSROOM_LOG_LEVEL=INFO

# Set to "true" to open CORS for http://localhost:5173 (Vite dev server).
# PRESSROOM_DEV=true
